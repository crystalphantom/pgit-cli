{
  "name": "pgit-cli",
  "version": "0.10.0",
  "description": "Agent-visible private config tracking for Git workspaces",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pgit": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && npm run postbuild",
    "postbuild": "node scripts/fix-imports.js",
    "dev": "ts-node src/cli.ts",
    "dev:website": "node scripts/serve-website.js",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/install-presets.cjs",
    "clean": "rm -rf dist",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --passWithNoTests --runInBand",
    "test:package": "node scripts/verify-package-install.cjs",
    "release": "release-it",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major",
    "changelog": "auto-changelog -p && git add CHANGELOG.md"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "scripts/install-presets.cjs",
    "presets.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "git",
    "private",
    "version-control",
    "cli",
    "typescript",
    "private-config",
    "agent-visible",
    "ai-agents",
    "codex",
    "claude-code"
  ],
  "author": "crystalphantom",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crystalphantom/pgit-cli.git"
  },
  "bugs": {
    "url": "https://github.com/crystalphantom/pgit-cli/issues"
  },
  "homepage": "https://github.com/crystalphantom/pgit-cli#readme",
  "dependencies": {
    "chalk": "^5.0.0",
    "commander": "^11.0.0",
    "fs-extra": "^11.1.0",
    "picomatch": "^4.0.4",
    "signale": "^1.4.0",
    "simple-git": "^3.36.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/fs-extra": "^11.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "auto-changelog": "^2.5.0",
    "eslint": "^9.35.0",
    "globals": "^16.3.0",
    "jest": "^30.1.3",
    "prettier": "^3.6.2",
    "release-it": "^20.2.0",
    "semver": "^7.7.2",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
